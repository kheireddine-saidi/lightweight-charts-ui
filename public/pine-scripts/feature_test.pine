//@version=5
indicator("PineTS Feature Test", overlay=true, max_lines_count=100, max_boxes_count=100, max_labels_count=100)

// ═══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════════

show_lines     = input.bool(true,  "Show Lines (line.new)")
show_boxes     = input.bool(true,  "Show Boxes (box.new)")
show_labels    = input.bool(true,  "Show Labels (label.new)")
show_fills     = input.bool(true,  "Show Fills (fill)")
show_hlines    = input.bool(true,  "Show HLines (hline)")
show_shapes    = input.bool(true,  "Show Shapes (plotshape)")
show_chars     = input.bool(true,  "Show Chars (plotchar)")
show_arrows    = input.bool(true,  "Show Arrows (plotarrow)")
show_bars      = input.bool(false, "Show Bar Overlay (plotbar)")
show_candles   = input.bool(false, "Show Candle Overlay (plotcandle)")
show_table     = input.bool(true,  "Show Table (table.new)")
show_linefill  = input.bool(true,  "Show Linefill (linefill.new)")
ma_length      = input.int(20, "MA Length", minval=2, maxval=200)
bb_mult        = input.float(2.0, "BB StdDev", minval=0.1, maxval=5.0, step=0.1)

// ═══════════════════════════════════════════════════════════════════════════════
// CALCULATIONS
// ═══════════════════════════════════════════════════════════════════════════════

// Bollinger Bands — drives fills and most plots
basis  = ta.sma(close, ma_length)
dev    = bb_mult * ta.stdev(close, ma_length)
upper  = basis + dev
lower  = basis - dev

// Fast/slow EMAs — for crossover signals
ema8   = ta.ema(close, 8)
ema21  = ta.ema(close, 21)

// RSI — drives arrow signals
rsi    = ta.rsi(close, 14)

// ATR — for sizing boxes/labels
atr    = ta.atr(14)

// Crossover signals
bull_cross = ta.crossover(ema8, ema21)
bear_cross = ta.crossunder(ema8, ema21)

// Overbought / Oversold
rsi_ob = rsi > 70
rsi_os = rsi < 30

// ═══════════════════════════════════════════════════════════════════════════════
// ── 1. PLOT() — line, area, circles, histogram ───────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════════

// Middle band — plain line
p_basis = plot(basis, "BB Basis", color=color.new(color.white, 40), linewidth=1, style=plot.style_line)

// Upper/lower bands — used for fill()
p_upper = plot(upper, "BB Upper", color=color.new(color.teal, 20), linewidth=1, style=plot.style_line)
p_lower = plot(lower, "BB Lower", color=color.new(color.teal, 20), linewidth=1, style=plot.style_line)

// EMA fast — stepline style
plot(ema8,  "EMA 8",  color=color.new(color.yellow, 0), linewidth=1, style=plot.style_stepline)

// EMA slow — area style (rendered on its own pane scale so stays visible)
plot(ema21, "EMA 21", color=color.new(color.orange, 60), linewidth=1, style=plot.style_line)

// RSI — histogram in its own scale (non-overlay value but tests histogram extraction)
plot(rsi - 50, "RSI-50", color=rsi > 50 ? color.new(color.green, 60) : color.new(color.red, 60),
     style=plot.style_histogram, linewidth=1)

// Circles on close price — tests style_circles extraction
plot(close, "Close Circles", color=color.new(color.silver, 70), style=plot.style_circles, linewidth=2)

// ═══════════════════════════════════════════════════════════════════════════════
// ── 2. HLINE() ───────────────────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════════

h_ob = show_hlines ? hline(70,  "RSI OB",      color=color.new(color.red,   20), linestyle=hline.style_dashed,  linewidth=1) : na
h_os = show_hlines ? hline(30,  "RSI OS",      color=color.new(color.green, 20), linestyle=hline.style_dashed,  linewidth=1) : na
h_mid = show_hlines ? hline(50, "RSI Mid",     color=color.new(color.gray,  40), linestyle=hline.style_dotted,  linewidth=1) : na

// ═══════════════════════════════════════════════════════════════════════════════
// ── 3. FILL() — between two plots and between two hlines ────────────────────
// ═══════════════════════════════════════════════════════════════════════════════

if show_fills
    // Fill between BB upper and lower — tests plot-to-plot fill
    fill(p_upper, p_lower,
         color = close > basis
             ? color.new(color.teal,  88)
             : color.new(color.purple, 88),
         title = "BB Fill")

    // Fill between RSI hlines — tests hline-to-hline fill
    if not na(h_ob) and not na(h_os)
        fill(h_ob, h_os, color=color.new(color.gray, 92), title="RSI Band Fill")

// ═══════════════════════════════════════════════════════════════════════════════
// ── 4. PLOTSHAPE() ────────────────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════════

if show_shapes
    // Bull cross — triangle up below bar
    plotshape(bull_cross,
              title    = "Bull Cross",
              style    = shape.triangleup,
              location = location.belowbar,
              color    = color.new(color.lime, 0),
              size     = size.small,
              text     = "X")

    // Bear cross — triangle down above bar
    plotshape(bear_cross,
              title    = "Bear Cross",
              style    = shape.triangledown,
              location = location.abovebar,
              color    = color.new(color.red, 0),
              size     = size.small,
              text     = "X")

    // RSI overbought — square above bar
    plotshape(rsi_ob,
              title    = "OB",
              style    = shape.square,
              location = location.abovebar,
              color    = color.new(color.orange, 20),
              size     = size.tiny)

    // RSI oversold — circle below bar
    plotshape(rsi_os,
              title    = "OS",
              style    = shape.circle,
              location = location.belowbar,
              color    = color.new(color.aqua, 20),
              size     = size.tiny)

// ═══════════════════════════════════════════════════════════════════════════════
// ── 5. PLOTCHAR() ─────────────────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════════

if show_chars
    // Star on bull cross
    plotchar(bull_cross,
             title    = "Bull Star",
             char     = "★",
             location = location.belowbar,
             color    = color.new(color.yellow, 0),
             size     = size.tiny,
             offset   = -1)

    // Arrow on bear cross
    plotchar(bear_cross,
             title    = "Bear Arrow",
             char     = "↓",
             location = location.abovebar,
             color    = color.new(color.fuchsia, 0),
             size     = size.tiny,
             offset   = -1)

// ═══════════════════════════════════════════════════════════════════════════════
// ── 6. PLOTARROW() ────────────────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════════

if show_arrows
    // Arrow driven by RSI deviation from 50 — positive = up arrow, negative = down
    arrow_val = rsi_ob ? -(rsi - 50) : rsi_os ? (50 - rsi) : 0
    plotarrow(arrow_val,
              title     = "RSI Arrow",
              colorup   = color.new(color.lime,    20),
              colordown = color.new(color.red,     20),
              minheight = 5,
              maxheight = 15)

// ═══════════════════════════════════════════════════════════════════════════════
// ── 7. PLOTBAR() + PLOTCANDLE() ───────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════════

if show_bars
    // Offset OHLC up by 2*ATR so overlay bars don't obscure main candles
    plotbar(open + 2*atr, high + 2*atr, low + 2*atr, close + 2*atr,
            title = "Offset Bars",
            color = close > open ? color.new(color.green, 40) : color.new(color.red, 40))

if show_candles
    plotcandle(open - 2*atr, high - 2*atr, low - 2*atr, close - 2*atr,
               title     = "Offset Candles",
               color     = close > open ? color.new(color.teal, 30) : color.new(color.maroon, 30),
               wickcolor = color.new(color.gray, 40))

// ═══════════════════════════════════════════════════════════════════════════════
// ── 8. LINE.NEW() ─────────────────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════════

// Persistent references so we can update them
var line trend_line    = na
var line support_line  = na
var int  swing_hi_bar  = na
var int  swing_lo_bar  = na
var float swing_hi     = na
var float swing_lo     = na

// Detect swing high/low (5-bar pivot)
is_swing_hi = high == ta.highest(high, 5) and bar_index >= 2
is_swing_lo = low  == ta.lowest(low,  5) and bar_index >= 2

if show_lines
    // Trend line: connect the last two swing highs
    if is_swing_hi
        if not na(swing_hi_bar) and not na(swing_hi)
            // Delete old trend line and draw new one
            line.delete(trend_line)
            trend_line := line.new(
                swing_hi_bar, swing_hi,
                bar_index,    high,
                color      = color.new(color.yellow, 0),
                width      = 2,
                style      = line.style_solid,
                xloc       = xloc.bar_index,
                extend     = extend.right)
        swing_hi_bar := bar_index
        swing_hi     := high

    // Support line: connect the last two swing lows
    if is_swing_lo
        if not na(swing_lo_bar) and not na(swing_lo)
            line.delete(support_line)
            support_line := line.new(
                swing_lo_bar, swing_lo,
                bar_index,    low,
                color      = color.new(color.aqua, 0),
                width      = 2,
                style      = line.style_dashed,
                xloc       = xloc.bar_index,
                extend     = extend.right)
        swing_lo_bar := bar_index
        swing_lo     := low

    // Short-lived annotation lines: one per bull/bear cross, auto-deleted after 10 bars
    if bull_cross
        line.new(bar_index, low  - atr * 0.5,
                 bar_index, low  - atr * 1.5,
                 color = color.lime, width = 2, xloc = xloc.bar_index)

    if bear_cross
        line.new(bar_index, high + atr * 0.5,
                 bar_index, high + atr * 1.5,
                 color = color.red,  width = 2, xloc = xloc.bar_index)

// ═══════════════════════════════════════════════════════════════════════════════
// ── 9. BOX.NEW() ──────────────────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════════

var box bb_box = na

if show_boxes
    // Redraw a Bollinger Band range box every bar (shows current BB width)
    box.delete(bb_box)
    bb_box := box.new(
        bar_index - ma_length, lower,
        bar_index,             upper,
        border_color = color.new(color.teal, 60),
        border_width = 1,
        bgcolor      = color.new(color.teal, 92),
        xloc         = xloc.bar_index)

    // Highlight consolidation: when BB is narrow (squeeze), draw a red box
    squeeze = (upper - lower) / basis < 0.02
    if squeeze
        box.new(bar_index - 1, low, bar_index, high,
                border_color = color.new(color.red, 40),
                bgcolor      = color.new(color.red, 85),
                xloc         = xloc.bar_index,
                text         = "Squeeze",
                text_color   = color.new(color.red, 20),
                text_size    = size.tiny)

// ═══════════════════════════════════════════════════════════════════════════════
// ── 10. LABEL.NEW() ───────────────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════════

if show_labels
    // Label bull/bear crosses with EMA values
    if bull_cross
        label.new(bar_index, low - atr,
                  text      = "▲ BULL\n" + str.tostring(math.round(ema8, 2)),
                  color     = color.new(color.lime, 20),
                  textcolor = color.new(color.black, 0),
                  style     = label.style_label_up,
                  size      = size.small,
                  xloc      = xloc.bar_index)

    if bear_cross
        label.new(bar_index, high + atr,
                  text      = "▼ BEAR\n" + str.tostring(math.round(ema8, 2)),
                  color     = color.new(color.red, 20),
                  textcolor = color.new(color.white, 0),
                  style     = label.style_label_down,
                  size      = size.small,
                  xloc      = xloc.bar_index)

    // Price label on the last bar (tests barstate.islast label)
    if barstate.islast
        label.new(bar_index, high + atr * 0.5,
                  text      = "◈ " + str.tostring(math.round(close, 2)) +
                              "\nRSI " + str.tostring(math.round(rsi, 1)),
                  color     = color.new(color.navy, 10),
                  textcolor = color.white,
                  style     = label.style_label_down,
                  size      = size.normal,
                  xloc      = xloc.bar_index)

// ═══════════════════════════════════════════════════════════════════════════════
// ── 11. LINEFILL.NEW() ────────────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════════

if show_linefill
    // Fill between two short lines that track the EMA spread each bar
    lf_top = line.new(bar_index - 1, ema8,  bar_index, ema8,
                      color = color.new(color.yellow, 80), xloc = xloc.bar_index)
    lf_bot = line.new(bar_index - 1, ema21, bar_index, ema21,
                      color = color.new(color.orange, 80), xloc = xloc.bar_index)
    linefill.new(lf_top, lf_bot,
                 color = ema8 > ema21
                     ? color.new(color.lime,   85)
                     : color.new(color.red,    85))

// ═══════════════════════════════════════════════════════════════════════════════
// ── 12. TABLE.NEW() ───────────────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════════

if show_table and barstate.islast
    t = table.new(position.top_right, 2, 7,
                  bgcolor      = color.new(color.black, 60),
                  border_width = 1,
                  border_color = color.new(color.gray, 60))

    // Header row
    table.cell(t, 0, 0, "Indicator",
               text_color = color.white,
               text_size  = size.small,
               bgcolor    = color.new(color.navy, 30))
    table.cell(t, 1, 0, "Value",
               text_color = color.white,
               text_size  = size.small,
               bgcolor    = color.new(color.navy, 30))

    // Data rows
    table.cell(t, 0, 1, "Close",      text_color = color.new(color.silver, 0), text_size = size.small)
    table.cell(t, 1, 1, str.tostring(math.round(close, 2)),
               text_color = close > open ? color.lime : color.red, text_size = size.small)

    table.cell(t, 0, 2, "BB Upper",   text_color = color.new(color.silver, 0), text_size = size.small)
    table.cell(t, 1, 2, str.tostring(math.round(upper, 2)),
               text_color = color.teal, text_size = size.small)

    table.cell(t, 0, 3, "BB Lower",   text_color = color.new(color.silver, 0), text_size = size.small)
    table.cell(t, 1, 3, str.tostring(math.round(lower, 2)),
               text_color = color.teal, text_size = size.small)

    table.cell(t, 0, 4, "RSI",        text_color = color.new(color.silver, 0), text_size = size.small)
    table.cell(t, 1, 4, str.tostring(math.round(rsi, 1)),
               text_color = rsi > 70 ? color.red : rsi < 30 ? color.lime : color.yellow,
               text_size  = size.small)

    table.cell(t, 0, 5, "EMA 8/21",   text_color = color.new(color.silver, 0), text_size = size.small)
    table.cell(t, 1, 5, ema8 > ema21 ? "▲ Bull" : "▼ Bear",
               text_color = ema8 > ema21 ? color.lime : color.red, text_size = size.small)

    table.cell(t, 0, 6, "Trend",      text_color = color.new(color.silver, 0), text_size = size.small)
    table.cell(t, 1, 6,
               close > upper ? "OB Zone" : close < lower ? "OS Zone" : "In Band",
               text_color = close > upper ? color.orange : close < lower ? color.aqua : color.white,
               text_size  = size.small)
